# Ollama 服务地址
OLLAMA_HOST=http://localhost:11434

# 对话模型
LLM_MODEL=codex-app

# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-m3

# 文本分块参数
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 检索返回数量
RETRIEVAL_K=10

# 对话历史保留轮数
CHAT_HISTORY_ROUNDS=10

# 数据存储目录
DATA_DIR=./data
MODEL_CACHE_DIR=./models

# 支持的文件格式
SUPPORTED_EXTENSIONS=.pdf,.docx,.txt,.md,.png,.jpg,.jpeg

# OCR 图片文字识别
ENABLE_OCR=true
OCR_LANGUAGE=chi_sim+eng
OCR_DPI=180
OCR_MAX_PAGES=30
ENABLE_VISION_OCR=true
VISION_MODEL=moondream

# 服务端口
GRADIO_PORT=7860
API_PORT=8000
